# Copy to .env and fill in. Do not commit .env.

# Required for ingestion (Apify actors)
APIFY_TOKEN=your_apify_token_here

# MongoDB: main pipeline data in DB "lead_discovery" (default when URI has no path).
# MONGODB_URI=mongodb://localhost:27017/lead_discovery
# Audit log (scraped/filtered/queued/sent) lives in a separate DB "lead_gen_audit" on same URI by default.
# Optional: use a dedicated URI for audit so logs survive if main DB is lost.
# MONGODB_URI_FOR_AUDIT=mongodb://localhost:27017/lead_gen_audit

# AI: use OpenAI and/or Google (Gemini). Google keys are rotated (GOOGLE1, GOOGLE2, GOOGLE3) to reduce rate limits.
# OPENAI_API_KEY=your_openai_key_here
# GOOGLE1=your_google_ai_studio_key_1
# GOOGLE2=your_google_ai_studio_key_2
# GOOGLE3=your_google_ai_studio_key_3

# Optional: Use small LLM to rescue posts that failed intent gate only (fewer false rejections). Set to 1 to enable.
# USE_LLM_RELEVANCE_OVERRIDE=1

# Optional: List-Unsubscribe (deliverability). Worker should set SES header from listUnsubscribe in queue doc.
# UNSUBSCRIBE_MAILTO=mailto:unsubscribe@yourdomain.com
# UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe

# Optional: Profile scrape before email (Apify actor ID). If set, we fetch author profile for personalization.
# PROFILE_SCRAPER_ACTOR_ID=apify/website-content-crawler

# AWS SES sending: use IAM user API key + secret (boto3 reads these from env)
# AWS_ACCESS_KEY_ID=your_ses_iam_access_key
# AWS_SECRET_ACCESS_KEY=your_ses_iam_secret_key
# AWS_REGION=us-east-1
# SES_FROM_EMAIL=notifications@yourdomain.com   # Must be verified in SES
# SES_REPLY_TO_EMAIL=support@yourdomain.com    # Optional reply-to header
# SES_DAILY_CAP=100                             # Max emails per day (default 100)
# OUTREACH_SENDER_NAME=Usman Sayed              # Name at end of generated emails (copy-paste ready; default: Usman Sayed)
# (Optional, for LocalStack only: AWS_SES_ENDPOINT_URL=http://localhost:4566)

# AWS Bedrock (LLM for filtering, scoring, personalization). Use ONE of the two options:
# Option A – Single Bedrock API key (no IAM keys needed for LLM):
# AWS_BEDROCK_API=your_bedrock_api_key_from_console
# MODEL_ID=amazon.nova-pro-v1:0
# Option B – IAM credentials (AWS_* above, or separate AWS2_* / CLAUDE_* for Bedrock)
# AWS2_ACCESS_KEY_ID=...
# AWS2_SECRET_ACCESS_KEY=...

# Optional: Hunter.io for contact discovery + email verification
# HUNTER_API_KEY=your_hunter_api_key

# Optional: Apify scrapers (email research) — proxy rotation & anti-bot
# APIFY_PROXY_GROUPS=RESIDENTIAL     # Use residential proxies (best anti-blocking)
# APIFY_PROXY_COUNTRY=US             # Two-letter country code for proxy geo
# APIFY_SCRAPER_RETRIES=5            # Max request retries (default 5)
# APIFY_SESSION_ROTATIONS=5          # Max session/IP rotations on block (default 5)

# Optional: Ingestion time limits (keep batches under ~10 min). Per-actor timeout; cap 600s.
# INGEST_ACTOR_TIMEOUT_SECS=600
# Optional: Max raw_posts to process in static filter per run (default 5000; keeps filter step fast).
# STATIC_FILTER_MAX_PER_RUN=5000

# Optional: Redis for Apify response caching (reduces redundant API calls)
# REDIS_URL=redis://localhost:6379/0

# Optional: TTL for raw_posts (auto-expire old posts, e.g. 90 days)
# RAW_POSTS_TTL_DAYS=90

# Optional: JSON-structured logs for production (Prometheus/Datadog parsing)
# LOG_JSON=1