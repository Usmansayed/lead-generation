{
    "title": "Twitter/X Lead Scraper",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "keywords": {
            "title": "Keywords to Search For",
            "type": "array",
            "description": "Lead generation keywords to search Twitter/X for",
            "editor": "stringList",
            "placeholderKey": "keyword",
            "placeholderValue": "e.g., hiring developer"
        },
        "maxResults": {
            "title": "Maximum Results",
            "type": "integer",
            "description": "Maximum number of leads to return (target 100+ in <1 min)",
            "default": 120,
            "minimum": 1,
            "maximum": 300
        },
        "useProxy": {
            "title": "Use Residential Proxy",
            "type": "boolean",
            "description": "Use Apify residential proxy for DuckDuckGo.",
            "default": true
        },
        "delayBetweenRequestsSec": {
            "title": "Delay Between Requests (sec)",
            "type": "number",
            "description": "Seconds between search requests.",
            "default": 0.4,
            "minimum": 0.1,
            "maximum": 2
        }
    },
    "required": ["keywords"]
}
